            <li class="panel-li"><a href="/admin/questions" class="panel-a">Вопросы</a></li>
            <li class="panel-empty-li"></li>
            <li class="panel-li"><a href="/admin/exchange-rate" class="panel-a">Курс валюты</a></li>
        </ul>
    </section>
}